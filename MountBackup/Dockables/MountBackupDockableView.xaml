<ResourceDictionary
    x:Class="MountBackup.Dockables.MountBackupDockableView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Floppy-disk glyph used as the dock panel icon -->
    <GeometryGroup x:Key="MountBackup_IconSVG" FillRule="EvenOdd">
        <PathGeometry Figures="M 8,0 L 74,0 L 100,26 L 100,92 Q 100,100 92,100 L 8,100 Q 0,100 0,92 L 0,8 Q 0,0 8,0 Z" />
        <RectangleGeometry Rect="22,0,46,32" />
        <RectangleGeometry Rect="50,6,12,20" />
        <RectangleGeometry Rect="16,52,68,40" RadiusX="4" RadiusY="4" />
        <RectangleGeometry Rect="24,62,52,6" />
        <RectangleGeometry Rect="24,76,52,6" />
    </GeometryGroup>

    <DataTemplate x:Key="MountBackup.Dockables.MountBackupDockableVM_Dockable">
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Saved pose" Margin="0,2,10,2" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SavedPoseText}" Margin="0,2" FontWeight="Bold" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Points to" Margin="0,2,10,2"
                           ToolTip="The physical direction the saved pose corresponds to — compare with where the telescope actually points" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SavedPointsToText}" Margin="0,2" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Saved at" Margin="0,2,10,2" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SavedTimestampText}" Margin="0,2" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Age" Margin="0,2,10,2" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SavedAgeText}" Margin="0,2" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Now equals" Margin="0,2,10,2" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentEquivalentRaDecText}" Margin="0,2" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Mount" Margin="0,2,10,2" />
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding MountStatusText}" Margin="0,2" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Status" Margin="0,2,10,2" />
                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RestoreStateText}" Margin="0,2" />
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                <CheckBox Content="Auto-restore on connect/unpark"
                          IsChecked="{Binding AutoRestoreEnabled, Mode=TwoWay}"
                          VerticalAlignment="Center" />
                <Button Content="Restore now"
                        Command="{Binding RestoreNowCommand}"
                        Margin="15,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        ToolTip="Sync the mount to the last saved position immediately (ignores auto-restore and threshold settings)" />
                <Button Content="Reset saved position"
                        Command="{Binding ResetCommand}"
                        Margin="10,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center" />
            </StackPanel>

            <Border Grid.Row="2" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                <ListBox ItemsSource="{Binding LogEntries}"
                         VirtualizingPanel.IsVirtualizing="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="{DynamicResource BackgroundBrush}"
                         Foreground="{DynamicResource PrimaryBrush}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                        <Style.Triggers>
                                            <!-- explicit colors: the theme's notification brushes are meant as banner
                                                 backgrounds and are barely readable as text on the dark background -->
                                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                <Setter Property="Foreground" Value="Orange" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Foreground" Value="Tomato" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding Timestamp, StringFormat=HH:mm:ss, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text="{Binding Message, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
